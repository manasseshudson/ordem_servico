<script>
        // Micro-interactions for form feedback
        document.querySelectorAll('input, textarea').forEach(element => {
            element.addEventListener('focus', () => {
                element.parentElement.classList.add('scale-[1.01]');
                element.parentElement.style.transition = 'transform 0.2s ease-out';
            });
            element.addEventListener('blur', () => {
                element.parentElement.classList.remove('scale-[1.01]');
            });
        });

        // Toggle hover states for checklist
        document.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
            checkbox.addEventListener('change', (e) => {
                const label = e.target.closest('label');
                if(e.target.checked) {
                    label.classList.add('bg-primary-fixed', 'border-primary/20');
                    label.classList.remove('hover:bg-surface-container');
                } else {
                    label.classList.remove('bg-primary-fixed', 'border-primary/20');
                    label.classList.add('hover:bg-surface-container');
                }
            });
        });
    </script>


